{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://offisim.local/schema/manifest-1.0.0.json",
  "title": "Offisim Package Manifest",
  "type": "object",
  "required": [
    "spec_version",
    "package",
    "compatibility",
    "requirements",
    "permissions",
    "assets",
    "integrity"
  ],
  "additionalProperties": false,
  "properties": {
    "spec_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "package": {
      "type": "object",
      "required": [
        "id",
        "kind",
        "version",
        "title",
        "license"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"
        },
        "kind": {
          "type": "string",
          "enum": [
            "employee",
            "skill",
            "sop",
            "company_template",
            "office_layout",
            "bundle",
            "prefab"
          ]
        },
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+(?:[-+][A-Za-z0-9.-]+)?$"
        },
        "title": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "summary": {
          "type": "string",
          "maxLength": 500
        },
        "license": {
          "type": "string",
          "minLength": 1,
          "maxLength": 120
        },
        "publisher": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "creator_handle": {
              "type": "string",
              "pattern": "^[a-z0-9_][a-z0-9_-]{1,38}$"
            },
            "display_name": {
              "type": "string",
              "maxLength": 120
            }
          }
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 32
          },
          "maxItems": 20
        }
      }
    },
    "compatibility": {
      "type": "object",
      "required": [
        "runtime_range",
        "schema_version",
        "supported_environments"
      ],
      "additionalProperties": false,
      "properties": {
        "runtime_range": {
          "type": "string",
          "minLength": 1,
          "maxLength": 64
        },
        "schema_version": {
          "type": "string",
          "minLength": 1,
          "maxLength": 32
        },
        "supported_environments": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "desktop",
              "docker",
              "web_limited"
            ]
          },
          "minItems": 1,
          "uniqueItems": true
        },
        "migration_notes": {
          "type": "string",
          "maxLength": 1000
        }
      }
    },
    "lineage": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "origin_listing_id": {
          "type": "string",
          "maxLength": 64
        },
        "origin_package_id": {
          "type": "string",
          "maxLength": 128
        },
        "forked_from_version": {
          "type": "string",
          "maxLength": 32
        },
        "derivative_of": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 128
          },
          "maxItems": 20
        }
      }
    },
    "requirements": {
      "type": "object",
      "required": [
        "required_capabilities",
        "required_mcps"
      ],
      "additionalProperties": false,
      "properties": {
        "required_capabilities": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 80
          },
          "uniqueItems": true
        },
        "required_mcps": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 80
          },
          "uniqueItems": true
        },
        "optional_mcps": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 80
          },
          "uniqueItems": true
        },
        "recommended_models": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "profile"
            ],
            "properties": {
              "profile": {
                "type": "string",
                "maxLength": 80
              },
              "reason": {
                "type": "string",
                "maxLength": 240
              },
              "provider_hints": {
                "type": "array",
                "items": {
                  "type": "string",
                  "maxLength": 80
                },
                "maxItems": 12
              }
            }
          },
          "maxItems": 12
        }
      }
    },
    "permissions": {
      "type": "object",
      "required": [
        "risk_class",
        "declares_secrets",
        "filesystem_scope",
        "network_scope"
      ],
      "additionalProperties": false,
      "properties": {
        "risk_class": {
          "type": "string",
          "enum": [
            "data_asset",
            "logic_asset",
            "privileged_asset"
          ]
        },
        "declares_secrets": {
          "type": "boolean"
        },
        "secret_slots_required": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 80
          },
          "uniqueItems": true
        },
        "filesystem_scope": {
          "type": "string",
          "enum": [
            "none",
            "workspace",
            "project",
            "custom_path"
          ]
        },
        "network_scope": {
          "type": "string",
          "enum": [
            "none",
            "limited",
            "unrestricted"
          ]
        },
        "notes": {
          "type": "string",
          "maxLength": 1000
        }
      }
    },
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "asset_id",
          "kind",
          "path"
        ],
        "additionalProperties": false,
        "properties": {
          "asset_id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:[._-][a-z0-9]+)*$"
          },
          "kind": {
            "type": "string",
            "enum": [
              "employee",
              "skill",
              "sop",
              "company_template",
              "office_layout",
              "bundle",
              "prefab"
            ]
          },
          "path": {
            "type": "string",
            "pattern": "^(assets|previews)/[A-Za-z0-9._/-]+$"
          },
          "entrypoint": {
            "type": "string",
            "maxLength": 80
          },
          "default_enabled": {
            "type": "boolean"
          },
          "recommended_models": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 80
            },
            "maxItems": 12
          }
        }
      }
    },
    "distribution": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source_url": {
          "type": "string",
          "format": "uri"
        },
        "mirror_policy": {
          "type": "string",
          "enum": [
            "registry_only",
            "external_only",
            "registry_or_external"
          ]
        },
        "artifact_size_bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "integrity": {
      "type": "object",
      "required": [
        "package_sha256"
      ],
      "additionalProperties": false,
      "properties": {
        "package_sha256": {
          "type": "string",
          "pattern": "^[a-fA-F0-9]{64}$"
        },
        "signature": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "alg": {
              "type": "string",
              "maxLength": 32
            },
            "key_id": {
              "type": "string",
              "maxLength": 128
            },
            "sig": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "files": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "path",
              "sha256"
            ],
            "additionalProperties": false,
            "properties": {
              "path": {
                "type": "string",
                "maxLength": 255
              },
              "sha256": {
                "type": "string",
                "pattern": "^[a-fA-F0-9]{64}$"
              }
            }
          }
        }
      }
    },
    "previews": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "icon_path": {
          "type": "string",
          "maxLength": 255
        },
        "hero_image_path": {
          "type": "string",
          "maxLength": 255
        },
        "readme_path": {
          "type": "string",
          "maxLength": 255
        }
      }
    },
    "custom": {
      "type": "object"
    }
  }
}