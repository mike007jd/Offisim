{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": [
    "scripts/check-platform-tauri-origin-sync.mjs",
    "apps/desktop/src-tauri/tauri.conf.json",
    "apps/platform/src/startup.ts"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "lint": {},
    "clean": {
      "cache": false
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
