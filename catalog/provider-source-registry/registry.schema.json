{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://offisim.local/schemas/provider-source-registry.json",
  "title": "Offisim Provider Source Registry",
  "type": "object",
  "required": ["version", "sources"],
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "sourceId",
          "sourceKind",
          "trustTier",
          "refreshMode",
          "ownedFields",
          "supportsProviders"
        ],
        "properties": {
          "sourceId": {
            "type": "string",
            "minLength": 1
          },
          "sourceKind": {
            "type": "string",
            "enum": [
              "official-live",
              "official-static",
              "community-aggregator",
              "curated-override"
            ]
          },
          "trustTier": {
            "type": "string",
            "enum": ["community", "official", "override"]
          },
          "refreshMode": {
            "type": "string",
            "enum": ["fixture", "manual", "remote-json"]
          },
          "ownedFields": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "supportsProviders": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "config": {
            "type": "object"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
