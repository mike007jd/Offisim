{
  "name": "offisim",
  "private": true,
  "packageManager": "pnpm@10.15.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "build:claude-agent-host": "node scripts/build-claude-agent-host.mjs",
    "build:codex-agent-host": "node scripts/build-codex-agent-host.mjs",
    "build:runtime-deps": "node scripts/build-runtime-deps.mjs",
    "check:ui-hygiene": "node scripts/check-ui-framework-hygiene.mjs",
    "dev:all": "node scripts/dev-all.mjs",
    "harness:edge": "node scripts/harness-edge.mjs",
    "harness:load": "node scripts/harness-load.mjs",
    "harness:contract": "node scripts/harness-contract.mjs",
    "harness:replay": "node scripts/harness-replay.mjs",
    "harness:provider-adapter": "node scripts/harness-provider-adapter.mjs",
    "harness:deterministic": "pnpm harness:contract && pnpm harness:replay && pnpm harness:provider-adapter",
    "harness:soak": "node scripts/harness-soak.mjs",
    "harness:chaos": "node scripts/harness-chaos.mjs",
    "harness:resume": "node scripts/harness-resume.mjs",
    "harness:record": "node scripts/harness-record.mjs",
    "harness:vcr": "node scripts/harness-vcr.mjs",
    "harness:context": "node scripts/harness-context.mjs",
    "harness:mcp-lifecycle": "node scripts/harness-mcp-lifecycle.mjs",
    "harness:engine-profiles": "node scripts/harness-engine-profiles.mjs",
    "harness:main-control-plane": "node scripts/harness-main-control-plane.mjs",
    "harness:model-bench": "node scripts/harness-model-bench.mjs",
    "harness:stream-tools": "node scripts/harness-stream-tools.mjs",
    "harness:smoke": "node scripts/harness-smoke.mjs",
    "harness:doc-engine": "node scripts/harness-doc-engine-parsers.mjs",
    "harness:chat-attachment-roundtrip": "node scripts/harness-chat-attachment-roundtrip.mjs",
    "platform:migration:drift": "node scripts/check-platform-migration-drift.mjs",
    "platform:auth-harness": "pnpm --filter @offisim/platform exec tsx ../../scripts/harness-platform-auth-boundaries.mts",
    "security:harness": "pnpm platform:auth-harness && pnpm --filter @offisim/platform exec tsx ../../scripts/harness-platform-body-limit-security.mts && pnpm --filter @offisim/platform exec tsx ../../scripts/harness-doc-engine-csv-security.mts && pnpm --filter @offisim/platform exec tsx ../../scripts/harness-git-source-security.mts && pnpm --filter @offisim/platform exec tsx ../../scripts/harness-registry-client-security.mts && pnpm --filter @offisim/platform exec tsx ../../scripts/harness-web-fetch-security.mts && pnpm --filter @offisim/platform exec tsx ../../scripts/harness-web-search-security.mts",
    "validate": "pnpm typecheck && pnpm provider:check",
    "typecheck": "turbo run typecheck",
    "provider:refresh": "node scripts/provider-source-registry/refresh.mjs",
    "provider:latest": "node scripts/provider-source-registry/latest.mjs",
    "provider:check": "node scripts/provider-source-registry/check-freshness.mjs",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "clean": "turbo run clean && rm -rf node_modules",
    "release:run": "node scripts/run-clean-release.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "version": "1.0.0-rc.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mike007jd/Offisim.git"
  },
  "homepage": "https://github.com/mike007jd/Offisim#readme",
  "bugs": {
    "url": "https://github.com/mike007jd/Offisim/issues"
  },
  "author": "Offisim Contributors",
  "pnpm": {
    "overrides": {
      "drizzle-orm": "0.45.2",
      "kysely": "^0.28.17",
      "fast-uri": "^3.1.2",
      "defu": "^6.1.5",
      "langsmith": "^0.6.0",
      "next": "^15.5.18",
      "vite": "^6.4.2"
    }
  }
}
