{
  "name": "offisim",
  "private": true,
  "packageManager": "pnpm@10.15.1",
  "engines": {
    "node": ">=22.19.0"
  },
  "scripts": {
    "build": "turbo run build",
    "build:pi-agent-host": "node scripts/build-pi-agent-host.mjs",
    "build:runtime-deps": "node scripts/build-runtime-deps.mjs",
    "check:ui-hygiene": "node scripts/check-ui-framework-hygiene.mjs",
    "check:ui-ux-drift": "node scripts/check-ui-ux-drift.mjs",
    "dev:all": "node scripts/dev-all.mjs",
    "harness:doc-engine": "node scripts/harness-doc-engine-parsers.mjs",
    "harness:chat-attachment-roundtrip": "node scripts/harness-chat-attachment-roundtrip.mjs",
    "platform:migration:drift": "node scripts/check-platform-migration-drift.mjs",
    "platform:auth-harness": "pnpm --filter @offisim/platform exec tsx ../../scripts/harness-platform-auth-boundaries.mts",
    "harness:pi-permission": "pnpm --filter @offisim/platform exec tsx ../../scripts/harness-pi-permission-modes.mts",
    "security:harness": "pnpm platform:auth-harness && pnpm --filter @offisim/platform exec tsx ../../scripts/harness-platform-body-limit-security.mts && pnpm --filter @offisim/platform exec tsx ../../scripts/harness-doc-engine-csv-security.mts && pnpm --filter @offisim/platform exec tsx ../../scripts/harness-git-source-security.mts && pnpm --filter @offisim/platform exec tsx ../../scripts/harness-registry-client-security.mts && pnpm --filter @offisim/platform exec tsx ../../scripts/harness-web-fetch-security.mts && pnpm --filter @offisim/platform exec tsx ../../scripts/harness-web-search-security.mts && pnpm harness:pi-permission",
    "harness:review-fixes": "node scripts/harness-review-fixes.mjs",
    "harness:studio-placement": "node scripts/harness-studio-placement.mjs",
    "validate": "pnpm typecheck && pnpm harness:review-fixes && pnpm harness:studio-placement && pnpm harness:pi-agent-host && pnpm check:pi-wire-contract && pnpm harness:pi-permission",
    "typecheck": "turbo run typecheck",
    "harness:pi-agent-host": "node scripts/harness-pi-agent-host.mjs",
    "check:pi-wire-contract": "node scripts/check-pi-wire-contract.mjs",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "clean": "turbo run clean && rm -rf node_modules",
    "release:run": "node scripts/run-clean-release.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "version": "1.0.0-rc.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mike007jd/Offisim.git"
  },
  "homepage": "https://github.com/mike007jd/Offisim#readme",
  "bugs": {
    "url": "https://github.com/mike007jd/Offisim/issues"
  },
  "author": "Offisim Contributors",
  "pnpm": {
    "overrides": {
      "drizzle-orm": "0.45.2",
      "kysely": "^0.28.17",
      "fast-uri": "^3.1.2",
      "defu": "^6.1.5",
      "langsmith": "^0.6.0",
      "shell-quote": "^1.8.4",
      "vite": "^6.4.2",
      "hono": "^4.12.25",
      "ws": "^8.21.0"
    }
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "0.79.6"
  }
}
