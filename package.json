{
  "name": "offisim",
  "private": true,
  "packageManager": "pnpm@10.15.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev:all": "node scripts/dev-all.mjs",
    "typecheck": "turbo run typecheck",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "clean": "turbo run clean && rm -rf node_modules",
    "launcher": "pnpm --filter @offisim/launcher dev"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "version": "1.0.0-rc.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mike007jd/Offisim.git"
  },
  "homepage": "https://github.com/mike007jd/Offisim#readme",
  "bugs": {
    "url": "https://github.com/mike007jd/Offisim/issues"
  },
  "author": "Offisim Contributors"
}
