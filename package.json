{
  "name": "offisim",
  "private": true,
  "packageManager": "pnpm@10.15.1",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "build:claude-agent-host": "node scripts/build-claude-agent-host.mjs",
    "build:codex-agent-host": "node scripts/build-codex-agent-host.mjs",
    "build:runtime-deps": "node scripts/build-runtime-deps.mjs",
    "dev:all": "node scripts/dev-all.mjs",
    "harness:edge": "node scripts/harness-edge.mjs",
    "harness:load": "node scripts/harness-load.mjs",
    "harness:contract": "node scripts/harness-contract.mjs",
    "harness:replay": "node scripts/harness-replay.mjs",
    "harness:provider-adapter": "node scripts/harness-provider-adapter.mjs",
    "harness:deterministic": "pnpm harness:contract && pnpm harness:replay && pnpm harness:provider-adapter",
    "harness:soak": "node scripts/harness-soak.mjs",
    "harness:chaos": "node scripts/harness-chaos.mjs",
    "harness:resume": "node scripts/harness-resume.mjs",
    "harness:record": "node scripts/harness-record.mjs",
    "harness:vcr": "node scripts/harness-vcr.mjs",
    "harness:context": "node scripts/harness-context.mjs",
    "harness:mcp-lifecycle": "node scripts/harness-mcp-lifecycle.mjs",
    "harness:engine-profiles": "node scripts/harness-engine-profiles.mjs",
    "harness:main-control-plane": "node scripts/harness-main-control-plane.mjs",
    "harness:model-bench": "node scripts/harness-model-bench.mjs",
    "harness:stream-tools": "node scripts/harness-stream-tools.mjs",
    "harness:smoke": "node scripts/harness-smoke.mjs",
    "harness:doc-engine": "node scripts/harness-doc-engine-parsers.mjs",
    "harness:chat-attachment-roundtrip": "node scripts/harness-chat-attachment-roundtrip.mjs",
    "tokens:emit": "pnpm --filter @offisim/ui-core... build && node scripts/emit-tailwind-theme.mjs",
    "tokens:check": "pnpm --filter @offisim/ui-core... build && node scripts/check-tailwind-theme.mjs",
    "tokens:lint-hex": "node scripts/lint-no-raw-hex.mjs",
    "ui:lint-hardcode": "node scripts/lint-ui-hardcode.mjs",
    "platform:migration:drift": "node scripts/check-platform-migration-drift.mjs",
    "platform:security-harness": "pnpm --filter @offisim/platform exec tsx ../../scripts/harness-platform-release-security.mts",
    "platform:auth-harness": "pnpm --filter @offisim/platform exec tsx ../../scripts/harness-platform-auth-boundaries.mts",
    "security:harness": "pnpm platform:security-harness && pnpm platform:auth-harness && pnpm --filter @offisim/platform exec tsx ../../scripts/harness-platform-body-limit-security.mts && pnpm --filter @offisim/platform exec tsx ../../scripts/harness-a2a-security.mts && pnpm --filter @offisim/platform exec tsx ../../scripts/harness-chat-attachment-security.mts && pnpm --filter @offisim/platform exec tsx ../../scripts/harness-doc-engine-csv-security.mts && pnpm --filter @offisim/platform exec tsx ../../scripts/harness-git-source-security.mts && pnpm --filter @offisim/platform exec tsx ../../scripts/harness-provider-list-refresh-security.mts && pnpm --filter @offisim/platform exec tsx ../../scripts/harness-registry-artifact-security.mts && pnpm --filter @offisim/platform exec tsx ../../scripts/harness-registry-client-security.mts && pnpm --filter @offisim/platform exec tsx ../../scripts/harness-sop-sync-security.mts && pnpm --filter @offisim/platform exec tsx ../../scripts/harness-web-fetch-security.mts && pnpm --filter @offisim/platform exec tsx ../../scripts/harness-web-search-security.mts",
    "install:materialization-harness": "pnpm --filter @offisim/platform exec tsx ../../scripts/harness-install-materialization.mts",
    "validate": "pnpm tokens:check && pnpm tokens:lint-hex && pnpm typecheck",
    "typecheck": "turbo run typecheck",
    "provider:refresh": "node scripts/provider-source-registry/refresh.mjs",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "clean": "turbo run clean && rm -rf node_modules",
    "release:run": "node scripts/run-clean-release.mjs"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "version": "1.0.0-rc.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mike007jd/Offisim.git"
  },
  "homepage": "https://github.com/mike007jd/Offisim#readme",
  "bugs": {
    "url": "https://github.com/mike007jd/Offisim/issues"
  },
  "author": "Offisim Contributors"
}
