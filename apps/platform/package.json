{
  "name": "@offisim/platform",
  "version": "1.0.0-rc.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm -C ../.. --filter @offisim/db-platform build && node ../../scripts/ensure-port-free.mjs 4100 && tsx watch src/index.ts",
    "prebuild": "node ../../scripts/check-platform-tauri-origin-sync.mjs",
    "build": "node ../../scripts/tsc-build-if-dist-missing.mjs --project tsconfig.json && mkdir -p dist/seed/payloads && cp src/seed/payloads/*.md dist/seed/payloads/",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "start": "node dist/index.js",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@offisim/asset-schema": "workspace:*",
    "@offisim/core": "workspace:*",
    "@offisim/db-platform": "workspace:*",
    "@offisim/renderer": "workspace:*",
    "@offisim/shared-types": "workspace:*",
    "@hono/node-server": "^1.14.0",
    "better-auth": "^1.5.5",
    "drizzle-orm": "^0.45.1",
    "fflate": "^0.8.2",
    "hono": "^4.7.0",
    "postgres": "^3.4.8",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "25.3.5",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "license": "MIT"
}
