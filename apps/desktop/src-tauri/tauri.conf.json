{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Offisim",
  "version": "1.0.0-rc.1",
  "identifier": "com.offisim.desktop",
  "build": {
    "beforeDevCommand": "node ../../scripts/tauri-before-dev.mjs desktop",
    "devUrl": "http://localhost:5176",
    "beforeBuildCommand": "pnpm build:frontend",
    "frontendDist": "../renderer/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Offisim",
        "create": true,
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https:; connect-src 'self' https: wss: ipc: http://ipc.localhost http://localhost:4100 https://localhost:4100 tauri://localhost; font-src 'self' data:; worker-src 'self' blob:; object-src 'none'; base-uri 'none'"
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:offisim.db"]
    },
    "deep-link": {
      "mobile": [],
      "desktop": {
        "schemes": ["offisim"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/pi-agent-host.mjs", "resources/node/bin/node"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
