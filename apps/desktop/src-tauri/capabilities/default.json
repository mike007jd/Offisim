{
  "identifier": "default",
  "description": "Default capabilities for Offisim desktop",
  "webviews": ["main"],
  "permissions": [
    "core:default",
    "cors-fetch:default",
    "deep-link:default",
    "fs:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "opener:default",
    "opener:allow-reveal-item-in-dir",
    "opener:allow-open-path"
  ]
}
