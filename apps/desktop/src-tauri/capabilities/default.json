{
  "identifier": "default",
  "description": "Default capabilities for Offisim desktop",
  "windows": ["main", "main-live"],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-load",
    "sql:allow-select",
    "sql:allow-execute",
    "sql:allow-close",
    "cors-fetch:default",
    "deep-link:default",
    "fs:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "opener:default",
    "opener:allow-reveal-item-in-dir",
    "opener:allow-open-path"
  ]
}
