{
  "name": "@offisim/install-core",
  "version": "1.0.0-rc.1",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/tsc-build-if-dist-missing.mjs --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@offisim/asset-schema": "workspace:*",
    "@offisim/db-local": "workspace:*",
    "@offisim/registry-client": "workspace:*",
    "@offisim/shared-types": "workspace:*",
    "fflate": "^0.8.2",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "license": "MIT"
}
