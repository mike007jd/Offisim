{
  "name": "@offisim/asset-schema",
  "version": "1.0.0-rc.2",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "generate": "node scripts/generate-validator.mjs",
    "build": "node scripts/generate-validator.mjs && tsc --project tsconfig.json && node scripts/copy-generated.mjs",
    "typecheck": "node scripts/generate-validator.mjs && tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo src/schema/manifest-validator.generated.js src/schema/manifest-validator.generated.d.ts"
  },
  "dependencies": {},
  "devDependencies": {
    "ajv": "^8.17.0",
    "typescript": "^5.7.0"
  },
  "license": "MIT"
}
