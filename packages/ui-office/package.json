{
  "name": "@offisim/ui-office",
  "version": "1.0.0-rc.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./scene": {
      "types": "./dist/scene.d.ts",
      "default": "./dist/scene.js"
    },
    "./web": {
      "types": "./dist/web.d.ts",
      "default": "./dist/web.js"
    },
    "./wizard": {
      "types": "./dist/components/onboarding/CompanyCreationWizard.d.ts",
      "default": "./dist/components/onboarding/CompanyCreationWizard.js"
    },
    "./dashboard": {
      "types": "./dist/components/dashboard/DashboardOverlay.d.ts",
      "default": "./dist/components/dashboard/DashboardOverlay.js"
    },
    "./employee-creator": {
      "types": "./dist/components/employees/EmployeeCreatorOverlay.d.ts",
      "default": "./dist/components/employees/EmployeeCreatorOverlay.js"
    },
    "./office-editor": {
      "types": "./dist/components/office/OfficeEditorOverlay.d.ts",
      "default": "./dist/components/office/OfficeEditorOverlay.js"
    },
    "./company-editor": {
      "types": "./dist/components/company/CompanyEditor.d.ts",
      "default": "./dist/components/company/CompanyEditor.js"
    },
    "./install": {
      "types": "./dist/components/install/InstallDialog.d.ts",
      "default": "./dist/components/install/InstallDialog.js"
    },
    "./studio": {
      "types": "./dist/components/studio/StudioPage.d.ts",
      "default": "./dist/components/studio/StudioPage.js"
    },
    "./kanban": {
      "types": "./dist/components/kanban/index.d.ts",
      "default": "./dist/components/kanban/index.js"
    },
    "./marketplace": {
      "types": "./dist/components/marketplace/index.d.ts",
      "default": "./dist/components/marketplace/index.js"
    },
    "./sop-view": {
      "types": "./dist/sop-view.d.ts",
      "default": "./dist/sop-view.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/tsc-build-if-dist-missing.mjs --project tsconfig.json && mkdir -p dist/components/install dist/components/workspace && cp src/components/install/install-animations.css dist/components/install/ && cp src/components/workspace/workspace-shell.css dist/components/workspace/",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@dicebear/collection": "^9.4.2",
    "@dicebear/core": "^9.4.2",
    "@offisim/asset-schema": "workspace:*",
    "@offisim/core": "workspace:*",
    "@offisim/doc-engine": "workspace:*",
    "@offisim/install-core": "workspace:*",
    "@offisim/registry-client": "workspace:*",
    "@offisim/renderer": "workspace:*",
    "@offisim/shared-types": "workspace:*",
    "@offisim/ui-core": "workspace:*",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "fflate": "^0.8.2",
    "lucide-react": "^0.577.0",
    "three": "^0.183.2",
    "zustand": "^5.0.12"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@types/react": "^19.0.0",
    "@types/three": "^0.183.1",
    "typescript": "^5.7.0"
  },
  "license": "MIT"
}
