{
  "name": "@aics/ui-office",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./scene": {
      "types": "./dist/scene.d.ts",
      "default": "./dist/scene.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json && cp src/components/install/install-animations.css dist/components/install/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@aics/asset-schema": "workspace:*",
    "@aics/core": "workspace:*",
    "@aics/doc-engine": "workspace:*",
    "@aics/install-core": "workspace:*",
    "@aics/registry-client": "workspace:*",
    "@aics/renderer": "workspace:*",
    "@aics/shared-types": "workspace:*",
    "@aics/ui-core": "workspace:*",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "lucide-react": "^0.577.0",
    "three": "^0.183.2"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-sql": "^2.3.2",
    "@types/react": "^19.0.0",
    "@types/three": "^0.183.1",
    "typescript": "^5.7.0"
  }
