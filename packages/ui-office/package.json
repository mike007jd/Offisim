{
  "name": "@aics/ui-office",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./scene": {
      "types": "./dist/scene.d.ts",
      "default": "./dist/scene.js"
    },
    "./wizard": {
      "types": "./dist/components/onboarding/CompanyCreationWizard.d.ts",
      "default": "./dist/components/onboarding/CompanyCreationWizard.js"
    },
    "./dashboard": {
      "types": "./dist/components/dashboard/DashboardOverlay.d.ts",
      "default": "./dist/components/dashboard/DashboardOverlay.js"
    },
    "./employee-creator": {
      "types": "./dist/components/employees/EmployeeCreatorOverlay.d.ts",
      "default": "./dist/components/employees/EmployeeCreatorOverlay.js"
    },
    "./office-editor": {
      "types": "./dist/components/office/OfficeEditorOverlay.d.ts",
      "default": "./dist/components/office/OfficeEditorOverlay.js"
    },
    "./settings": {
      "types": "./dist/components/settings/SettingsDialog.d.ts",
      "default": "./dist/components/settings/SettingsDialog.js"
    },
    "./company-editor": {
      "types": "./dist/components/company/CompanyEditor.d.ts",
      "default": "./dist/components/company/CompanyEditor.js"
    },
    "./install": {
      "types": "./dist/components/install/InstallDialog.d.ts",
      "default": "./dist/components/install/InstallDialog.js"
    }
  },
  "scripts": {
    "build": "tsc --project tsconfig.json && cp src/components/install/install-animations.css dist/components/install/",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "clean": "rm -rf dist",
    "test": "vitest run"
  },
  "dependencies": {
    "@aics/asset-schema": "workspace:*",
    "@aics/core": "workspace:*",
    "@aics/doc-engine": "workspace:*",
    "@aics/install-core": "workspace:*",
    "@aics/registry-client": "workspace:*",
    "@aics/renderer": "workspace:*",
    "@aics/shared-types": "workspace:*",
    "@aics/ui-core": "workspace:*",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "lucide-react": "^0.577.0",
    "three": "^0.183.2",
    "zustand": "^5.0.12"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-sql": "^2.3.2",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/three": "^0.183.1",
    "jsdom": "^26.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
