{
  "name": "@aics/core",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./drizzle": {
      "types": "./dist/drizzle.d.ts",
      "import": "./dist/drizzle.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    },
    "./events": {
      "types": "./dist/events/event-factories.d.ts",
      "import": "./dist/events/event-factories.js"
    },
    "./dist/*": "./dist/*"
  },
  "sideEffects": false,
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:smoke:adapter": "vitest run src/__tests__/smoke/adapter.smoke.ts --passWithNoTests",
    "test:smoke:graph": "vitest run src/__tests__/smoke/graph.smoke.ts --passWithNoTests",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.17.0",
    "@aics/db-local": "workspace:*",
    "@aics/install-core": "workspace:*",
    "@aics/shared-types": "workspace:*",
    "@anthropic-ai/sdk": "^0.78.0",
    "@langchain/core": "^1.1.31",
    "@langchain/langgraph": "^1.2.1",
    "@langchain/langgraph-checkpoint-sqlite": "^1.0.1",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "openai": "^6.27.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.39.3",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
