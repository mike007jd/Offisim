{
  "name": "@offisim/core",
  "version": "1.0.0-rc.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./drizzle": {
      "types": "./dist/drizzle.d.ts",
      "import": "./dist/drizzle.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    },
    "./events": {
      "types": "./dist/events/event-factories.d.ts",
      "import": "./dist/events/event-factories.js"
    },
    "./dist/*": "./dist/*"
  },
  "sideEffects": false,
  "scripts": {
    "build": "node ../../scripts/tsc-build-if-dist-missing.mjs --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.2.117",
    "@anthropic-ai/sdk": "^0.90.0",
    "@langchain/core": "^1.1.40",
    "@langchain/langgraph": "^1.2.9",
    "@langchain/langgraph-checkpoint-sqlite": "^1.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@offisim/db-local": "workspace:*",
    "@offisim/install-core": "workspace:*",
    "@offisim/shared-types": "workspace:*",
    "@openai/agents": "0.8.5",
    "fflate": "^0.8.2",
    "js-yaml": "^4.1.1",
    "openai": "^6.34.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.39.3",
    "typescript": "^5.7.0"
  },
  "license": "MIT"
}
