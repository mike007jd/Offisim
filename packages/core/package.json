{
  "name": "@offisim/core",
  "version": "1.0.0-rc.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./drizzle": {
      "types": "./dist/drizzle.d.ts",
      "import": "./dist/drizzle.js"
    },
    "./browser": {
      "types": "./dist/browser.d.ts",
      "import": "./dist/browser.js"
    },
    "./runtime": {
      "types": "./dist/runtime-public.d.ts",
      "import": "./dist/runtime-public.js"
    },
    "./harness": {
      "types": "./dist/harness-public.d.ts",
      "import": "./dist/harness-public.js"
    },
    "./llm": {
      "types": "./dist/llm-public.d.ts",
      "import": "./dist/llm-public.js"
    },
    "./mcp": {
      "types": "./dist/mcp-public.d.ts",
      "import": "./dist/mcp-public.js"
    },
    "./services": {
      "types": "./dist/services-public.d.ts",
      "import": "./dist/services-public.js"
    },
    "./engine": {
      "types": "./dist/engine-public.d.ts",
      "import": "./dist/engine-public.js"
    },
    "./tools": {
      "types": "./dist/tools-public.d.ts",
      "import": "./dist/tools-public.js"
    },
    "./middleware": {
      "types": "./dist/middleware-public.d.ts",
      "import": "./dist/middleware-public.js"
    },
    "./templates": {
      "types": "./dist/templates/index.d.ts",
      "import": "./dist/templates/index.js"
    },
    "./events": {
      "types": "./dist/events/event-factories.d.ts",
      "import": "./dist/events/event-factories.js"
    },
    "./dist/*": "./dist/*"
  },
  "sideEffects": false,
  "scripts": {
    "build": "node ../../scripts/tsc-build-if-dist-missing.mjs --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.0",
    "@earendil-works/pi-coding-agent": "0.79.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@offisim/db-local": "workspace:*",
    "@offisim/doc-engine": "workspace:*",
    "@offisim/install-core": "workspace:*",
    "@offisim/pi-agent": "workspace:*",
    "@offisim/pi-ai": "workspace:*",
    "@offisim/shared-types": "workspace:*",
    "fflate": "^0.8.2",
    "js-yaml": "^4.1.1",
    "openai": "^6.36.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/js-yaml": "^4.0.9",
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.39.3",
    "typescript": "^5.7.0"
  },
  "license": "MIT"
}
