{
  "id": "local-tool-routing-avoids-external-a2a",
  "category": "interaction-modes",
  "entryMode": "boss_chat",
  "interactionMode": "boss_proxy",
  "seed": {
    "company": { "companyId": "company-local-tool-routing", "name": "Local Tool Routing Co" },
    "thread": { "threadId": "thread-local-tool-routing", "status": "running" },
    "employees": [
      { "id": "emp-internal-tools", "name": "Internal Tool Engineer", "role": "engineer" },
      {
        "id": "emp-external-a2a",
        "name": "External A2A Worker",
        "role": "developer",
        "isExternal": true,
        "a2aUrl": "http://localhost:4100",
        "brandKey": "codex"
      }
    ]
  },
  "tools": [
    {
      "name": "write_file",
      "description": "Write a file.",
      "parameters": {
        "type": "object",
        "properties": {
          "path": { "type": "string" },
          "content": { "type": "string" }
        },
        "required": ["path", "content"]
      }
    }
  ],
  "toolFixtures": {
    "write_file": [
      {
        "success": true,
        "result": "Successfully wrote 26 bytes to rc-live-routing-proof.txt"
      }
    ]
  },
  "initialState": {
    "messages": [
      {
        "role": "user",
        "content": "Use actual tools: write_file rc-live-routing-proof.txt, read_file it back, then run bash sleep 35."
      }
    ]
  },
  "llmTurns": [
    {
      "id": "boss-wrongly-picks-external",
      "match": { "contains": "write_file rc-live-routing-proof.txt" },
      "content": "{\"action\":\"direct_delegate\",\"targetEmployeeId\":\"emp-external-a2a\",\"reason\":\"single worker\"}"
    },
    {
      "id": "manager-wrongly-assigns-external",
      "match": { "contains": "Available employees:" },
      "content": "{\"intent\":\"work\",\"assignments\":[{\"taskType\":\"code\",\"employeeId\":\"emp-external-a2a\",\"description\":\"Create rc-live-routing-proof.txt with write_file and report the result.\"}]}"
    },
    {
      "id": "pm-wrongly-plans-external",
      "match": { "contains": "Intent: Use actual tools" },
      "content": "{\"summary\":\"Create routing proof\",\"steps\":[{\"stepIndex\":0,\"description\":\"Create proof file\",\"tasks\":[{\"taskType\":\"code\",\"employeeId\":\"emp-external-a2a\",\"description\":\"Create rc-live-routing-proof.txt with write_file and report the result.\",\"dependsOnStepOutput\":false}]}]}"
    },
    {
      "id": "internal-employee-write-file",
      "match": {
        "contains": "Create rc-live-routing-proof.txt",
        "toolNames": ["write_file"]
      },
      "content": "",
      "toolCalls": [
        {
          "id": "call-routing-proof-write",
          "name": "write_file",
          "arguments": {
            "path": "rc-live-routing-proof.txt",
            "content": "OFFISIM_LOCAL_TOOL_ROUTING"
          }
        }
      ]
    },
    {
      "id": "internal-employee-final",
      "match": { "contains": "Successfully wrote 26 bytes to rc-live-routing-proof.txt" },
      "content": "Routed local tool task completed."
    }
  ],
  "runs": [{}],
  "assertions": [
    { "kind": "taskRunsExcludeEmployee", "employeeId": "emp-external-a2a" },
    { "kind": "mcpAuditContains", "toolName": "write_file" },
    { "kind": "threadStatusIs", "status": "completed" },
    { "kind": "finalOutputNotContains", "contains": "Load failed" }
  ]
}
