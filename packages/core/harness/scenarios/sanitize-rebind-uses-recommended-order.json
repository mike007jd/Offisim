{
  "id": "sanitize-rebind-uses-recommended-order",
  "category": "interaction-modes",
  "entryMode": "boss_chat",
  "interactionMode": "boss_proxy",
  "seed": {
    "company": { "companyId": "company-sanitize-rebind", "name": "Sanitize Rebind Co" },
    "thread": { "threadId": "thread-sanitize-rebind", "status": "running" },
    "employees": [
      { "id": "emp-recommended", "name": "Recommended Worker", "role": "engineer" },
      { "id": "emp-other", "name": "Other Worker", "role": "engineer" }
    ]
  },
  "tools": [
    {
      "name": "read_file",
      "description": "Read a file.",
      "parameters": {
        "type": "object",
        "properties": { "path": { "type": "string" } },
        "required": ["path"]
      }
    }
  ],
  "toolFixtures": {
    "read_file": [{ "success": true, "result": "RC_SANITIZE_PROOF" }]
  },
  "initialState": {
    "messages": [
      {
        "role": "user",
        "content": "Read README.md so we can quote the intro."
      }
    ]
  },
  "llmTurns": [
    {
      "id": "boss-decides-delegate",
      "match": { "contains": "Read README.md so we" },
      "content": "{\"action\":\"delegate\",\"reason\":\"task requires execution\"}"
    },
    {
      "id": "manager-recommends-both",
      "match": { "contains": "Available employees:" },
      "content": "{\"intent\":\"work\",\"assignments\":[{\"taskType\":\"code\",\"employeeId\":\"emp-recommended\",\"description\":\"Read README.md and quote intro\"},{\"taskType\":\"code\",\"employeeId\":\"emp-other\",\"description\":\"Backup worker\"}]}"
    },
    {
      "id": "pm-plan-with-missing-employee",
      "match": { "contains": "Intent: Read README.md" },
      "content": "{\"summary\":\"Read README intro\",\"recommendedEmployees\":[\"emp-recommended\",\"emp-other\"],\"steps\":[{\"stepIndex\":0,\"description\":\"Read README\",\"tasks\":[{\"taskType\":\"code\",\"employeeId\":\"emp-missing-from-roster\",\"description\":\"Read README.md and quote intro\",\"dependsOnStepOutput\":false}]}]}"
    },
    {
      "id": "recommended-employee-read",
      "match": {
        "contains": "Read README.md and quote intro",
        "toolNames": ["read_file"]
      },
      "content": "",
      "toolCalls": [
        {
          "id": "call-read-intro",
          "name": "read_file",
          "arguments": { "path": "README.md" }
        }
      ]
    },
    {
      "id": "recommended-employee-final",
      "match": { "contains": "RC_SANITIZE_PROOF" },
      "content": "Intro quoted from README.md."
    }
  ],
  "runs": [{}],
  "assertions": [
    { "kind": "taskRunsExcludeEmployee", "employeeId": "emp-missing-from-roster" },
    {
      "kind": "eventEmitted",
      "eventType": "task.assignment.rerouted",
      "payloadEquals": {
        "source": "pm-planner",
        "reason": "employee-not-found",
        "requestedEmployeeId": "emp-missing-from-roster",
        "resolvedEmployeeId": "emp-recommended"
      },
      "count": 1
    },
    { "kind": "threadStatusIs", "status": "completed" }
  ]
}
