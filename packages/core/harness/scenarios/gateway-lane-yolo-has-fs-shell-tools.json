{
  "id": "gateway-lane-yolo-has-fs-shell-tools",
  "category": "interaction-modes",
  "entryMode": "boss_chat",
  "interactionMode": "yolo",
  "seed": {
    "company": { "companyId": "company-yolo-tools", "name": "YOLO Tools Co" },
    "thread": { "threadId": "thread-yolo-tools", "status": "running" },
    "employees": [{ "id": "emp-yolo-tools", "name": "YOLO Master", "role": "yolo_master" }]
  },
  "builtinTools": [
    {
      "name": "read_file",
      "description": "Read a file.",
      "parameters": {
        "type": "object",
        "properties": { "path": { "type": "string" } },
        "required": ["path"]
      }
    },
    {
      "name": "write_file",
      "description": "Write a file.",
      "parameters": {
        "type": "object",
        "properties": { "path": { "type": "string" }, "content": { "type": "string" } },
        "required": ["path", "content"]
      }
    },
    {
      "name": "bash",
      "description": "Run a shell command.",
      "parameters": {
        "type": "object",
        "properties": { "command": { "type": "string" }, "cwd": { "type": "string" } },
        "required": ["command"]
      }
    }
  ],
  "initialState": {},
  "llmTurns": [
    {
      "id": "yolo-tools-visible",
      "match": { "toolNames": ["read_file", "write_file", "bash"] },
      "content": "TOOLS_VISIBLE"
    }
  ],
  "runs": [{}],
  "assertions": [{ "kind": "firstGraphNodeIs", "nodeName": "yolo-master" }]
}
