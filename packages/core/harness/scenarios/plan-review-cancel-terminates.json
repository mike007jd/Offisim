{
  "id": "plan-review-cancel-terminates",
  "category": "interaction",
  "entryMode": "boss_chat",
  "interactionMode": "human_in_loop",
  "seed": {
    "company": { "companyId": "company-plan-cancel", "name": "Plan Cancel Co" },
    "thread": { "threadId": "thread-plan-cancel", "status": "running" },
    "employees": [{ "id": "emp-plan-cancel", "name": "Casey", "role": "engineer" }]
  },
  "llmTurns": [
    {
      "id": "pm-plan",
      "content": "{\"summary\":\"Plan that will be cancelled\",\"steps\":[{\"stepIndex\":0,\"description\":\"Do cancelled work\",\"tasks\":[{\"taskType\":\"general\",\"employeeId\":\"emp-plan-cancel\",\"description\":\"Do cancelled work\",\"dependsOnStepOutput\":false}]}]}"
    }
  ],
  "initialState": {
    "managerDirective": {
      "intent": "Plan cancellable work",
      "recommendedEmployees": ["emp-plan-cancel"]
    }
  },
  "runs": [
    {
      "startAt": "pm_planner",
      "expectError": "PLAN_REVIEW_REQUIRED",
      "resolveAfterRun": [{ "kind": "plan_review", "selectedOptionId": "cancel" }]
    },
    { "startAt": "pm_planner" }
  ],
  "assertions": [
    {
      "kind": "interactionHistoryContains",
      "interactionKind": "plan_review",
      "selectedOptionId": "cancel",
      "status": "resolved",
      "payloadType": "plan_review_payload"
    },
    { "kind": "threadStatusIs", "status": "cancelled" },
    { "kind": "noEmployeeAfterCancel" }
  ]
}
