{
  "id": "builtin-tool-registry-audit-path",
  "category": "default-harness",
  "entryMode": "boss_chat",
  "interactionMode": "direct_to_employee",
  "seed": {
    "company": { "companyId": "company-builtin-registry", "name": "Builtin Registry Co" },
    "thread": { "threadId": "thread-builtin-registry", "status": "running" },
    "employees": [{ "id": "emp-builtin-registry", "name": "Registry Engineer", "role": "engineer" }],
    "taskRuns": [
      {
        "id": "task-builtin-registry",
        "employeeId": "emp-builtin-registry",
        "taskType": "code",
        "input": {
          "description": "Use read_file to inspect project metadata through the default gateway path."
        }
      }
    ]
  },
  "builtinTools": [
    {
      "name": "read_file",
      "description": "Read a file.",
      "parameters": {
        "type": "object",
        "properties": { "path": { "type": "string" } },
        "required": ["path"]
      }
    }
  ],
  "initialState": {
    "pendingAssignments": [
      {
        "taskType": "code",
        "employeeId": "emp-builtin-registry",
        "assigneeKind": "employee",
        "assigneeName": "Registry Engineer",
        "taskRunId": "task-builtin-registry",
        "stepIndex": 0,
        "inputJson": {
          "description": "Use read_file to inspect project metadata through the default gateway path.",
          "stepIndex": 0
        }
      }
    ],
    "dispatchedStepIndices": [0],
    "recentToolResults": []
  },
  "llmTurns": [
    {
      "id": "employee-read-file",
      "match": {
        "contains": "Use read_file to inspect project metadata",
        "toolNames": ["read_file"]
      },
      "content": "",
      "toolCalls": [
        {
          "id": "call-builtin-read",
          "name": "read_file",
          "arguments": { "path": "package.json" }
        }
      ]
    },
    {
      "id": "employee-final-after-read",
      "match": { "contains": "\"tool\":\"read_file\"" },
      "content": "Builtin registry audit path observed."
    }
  ],
  "runs": [{ "startAt": "employee" }],
  "assertions": [
    { "kind": "taskRunStatusIs", "taskRunId": "task-builtin-registry", "status": "completed" },
    { "kind": "mcpAuditContains", "toolName": "read_file", "serverName": "builtin" },
    {
      "kind": "eventEmitted",
      "eventType": "tool.execution.telemetry",
      "payloadEquals": {
        "toolName": "read_file",
        "toolType": "builtin",
        "serverName": "builtin",
        "status": "completed"
      }
    },
    {
      "kind": "conversationStateContains",
      "pendingToolCalls": 0,
      "toolResults": 1,
      "permissionDenials": 0,
      "activeTaskRunId": "task-builtin-registry",
      "checkpointTaskRunId": "task-builtin-registry",
      "discoveredTools": [
        {
          "name": "read_file",
          "surface": "builtin",
          "serverName": "builtin",
          "permissionIdentity": "mcp:builtin:read_file",
          "exposedToLlm": true
        }
      ]
    },
    { "kind": "toolExecutions", "count": 0 }
  ]
}
