{
  "id": "non-tool-lane-omits-all-runtime-tools",
  "category": "interaction-modes",
  "entryMode": "boss_chat",
  "interactionMode": "yolo",
  "llmToolCallsEnabled": false,
  "seed": {
    "company": { "companyId": "company-non-tool-lane", "name": "Non Tool Lane Co" },
    "thread": { "threadId": "thread-non-tool-lane", "status": "running" },
    "employees": [{ "id": "emp-non-tool-lane", "name": "SDK Lane Engineer", "role": "yolo_master" }]
  },
  "tools": [
    {
      "name": "fixture_tool",
      "description": "A deterministic MCP-style fixture tool.",
      "parameters": {
        "type": "object",
        "properties": { "input": { "type": "string" } },
        "required": ["input"]
      }
    }
  ],
  "builtinTools": [
    {
      "name": "read_file",
      "description": "Read a file.",
      "parameters": {
        "type": "object",
        "properties": { "path": { "type": "string" } },
        "required": ["path"]
      }
    },
    {
      "name": "write_file",
      "description": "Write a file.",
      "parameters": {
        "type": "object",
        "properties": { "path": { "type": "string" }, "content": { "type": "string" } },
        "required": ["path", "content"]
      }
    },
    {
      "name": "bash",
      "description": "Run a shell command.",
      "parameters": {
        "type": "object",
        "properties": { "command": { "type": "string" }, "cwd": { "type": "string" } },
        "required": ["command"]
      }
    }
  ],
  "initialState": {},
  "llmTurns": [
    {
      "id": "sdk-lane-tools-hidden",
      "match": {
        "absentToolNames": [
          "read_file",
          "write_file",
          "bash",
          "fixture_tool",
          "todo_create",
          "todo_update",
          "todo_list",
          "handoff_to"
        ]
      },
      "content": "NO_TOOLS_EXPOSED"
    }
  ],
  "runs": [{}],
  "assertions": [{ "kind": "firstGraphNodeIs", "nodeName": "yolo-master" }]
}
