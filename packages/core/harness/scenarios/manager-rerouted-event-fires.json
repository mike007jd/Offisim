{
  "id": "manager-rerouted-event-fires",
  "category": "interaction-modes",
  "entryMode": "boss_chat",
  "interactionMode": "boss_proxy",
  "seed": {
    "company": { "companyId": "company-manager-reroute", "name": "Manager Reroute Co" },
    "thread": { "threadId": "thread-manager-reroute", "status": "running" },
    "employees": [
      { "id": "emp-internal-reroute", "name": "Internal Engineer", "role": "engineer" },
      { "id": "emp-internal-backup", "name": "Internal Backup", "role": "engineer" },
      {
        "id": "emp-external-reroute",
        "name": "External A2A Worker",
        "role": "developer",
        "isExternal": true,
        "a2aUrl": "http://localhost:4100",
        "brandKey": "codex"
      }
    ]
  },
  "tools": [
    {
      "name": "read_file",
      "description": "Read a file.",
      "parameters": {
        "type": "object",
        "properties": { "path": { "type": "string" } },
        "required": ["path"]
      }
    }
  ],
  "toolFixtures": {
    "read_file": [{ "success": true, "result": "RC_REROUTE_PROOF" }]
  },
  "initialState": {
    "messages": [
      {
        "role": "user",
        "content": "Read README.md and report the install section."
      }
    ]
  },
  "llmTurns": [
    {
      "id": "boss-decides-delegate",
      "match": { "contains": "Read README.md and report" },
      "content": "{\"action\":\"delegate\",\"reason\":\"task requires execution\"}"
    },
    {
      "id": "manager-picks-external",
      "match": { "contains": "Available employees:" },
      "content": "{\"intent\":\"work\",\"assignments\":[{\"taskType\":\"code\",\"employeeId\":\"emp-external-reroute\",\"description\":\"Read README.md install section\"}]}"
    },
    {
      "id": "pm-plan-internal",
      "match": { "contains": "Intent: Read README.md" },
      "content": "{\"summary\":\"Read README install section\",\"steps\":[{\"stepIndex\":0,\"description\":\"Read README\",\"tasks\":[{\"taskType\":\"code\",\"employeeId\":\"emp-internal-reroute\",\"description\":\"Read README.md install section\",\"dependsOnStepOutput\":false}]}]}"
    },
    {
      "id": "internal-employee-read",
      "match": {
        "contains": "Read README.md install section",
        "toolNames": ["read_file"]
      },
      "content": "",
      "toolCalls": [
        {
          "id": "call-read-readme",
          "name": "read_file",
          "arguments": { "path": "README.md" }
        }
      ]
    },
    {
      "id": "internal-employee-final",
      "match": { "contains": "RC_REROUTE_PROOF" },
      "content": "Install section retrieved from README.md."
    }
  ],
  "runs": [{}],
  "assertions": [
    { "kind": "taskRunsExcludeEmployee", "employeeId": "emp-external-reroute" },
    {
      "kind": "eventEmitted",
      "eventType": "task.assignment.rerouted",
      "payloadEquals": {
        "source": "manager",
        "reason": "requires-local-tools",
        "requestedEmployeeId": "emp-external-reroute",
        "resolvedEmployeeId": "emp-internal-reroute"
      },
      "count": 1
    },
    { "kind": "threadStatusIs", "status": "completed" }
  ]
}
