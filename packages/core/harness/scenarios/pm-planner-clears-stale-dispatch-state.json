{
  "id": "pm-planner-clears-stale-dispatch-state",
  "category": "graph",
  "entryMode": "boss_chat",
  "seed": {
    "company": { "companyId": "company-pm-planner-clears-stale-dispatch-state", "name": "Plan Reset Co" },
    "thread": { "threadId": "thread-pm-planner-clears-stale-dispatch-state", "status": "running" },
    "employees": [
      { "id": "emp-plan-reset", "name": "Plan Engineer", "role": "engineer" }
    ]
  },
  "tools": [
    {
      "name": "pnpm-test",
      "description": "Run package tests.",
      "parameters": { "type": "object", "properties": { "command": { "type": "string" } } }
    }
  ],
  "toolFixtures": {
    "pnpm-test": [
      { "success": true, "result": { "ok": true, "command": "pnpm test -- stale-reset" } }
    ]
  },
  "initialState": {
    "managerDirective": {
      "intent": "Build the requested plan deliverable",
      "recommendedEmployees": ["emp-plan-reset"]
    },
    "completedStepIndices": [0],
    "dispatchedStepIndices": [0],
    "currentStepIndex": 1
  },
  "llmTurns": [
    {
      "id": "pm-new-plan",
      "match": { "contains": "Build the requested plan deliverable" },
      "content": "{\"summary\":\"Build plan deliverable after stale checkpoint\",\"steps\":[{\"stepIndex\":0,\"description\":\"Create deliverable\",\"tasks\":[{\"taskType\":\"code\",\"employeeId\":\"emp-plan-reset\",\"description\":\"Create the deliverable and verify it\",\"dependsOnStepOutput\":false}]}]}"
    },
    {
      "id": "employee-tool",
      "match": { "contains": "Create the deliverable and verify it", "toolNames": ["pnpm-test"] },
      "content": "",
      "toolCalls": [
        {
          "id": "tc-run-test",
          "name": "pnpm-test",
          "arguments": { "command": "pnpm test -- stale-reset" }
        }
      ]
    },
    {
      "id": "employee-final",
      "match": { "contains": "pnpm test -- stale-reset" },
      "content": "STALE_DISPATCH_RESET_EMPLOYEE_DONE"
    }
  ],
  "runs": [{ "startAt": "pm_planner" }],
  "assertions": [
    { "kind": "toolExecutions", "count": 1 },
    { "kind": "graphStateArrayEquals", "field": "blockedStepIndices", "value": [] },
    { "kind": "threadStatusIs", "status": "completed" }
  ]
}
