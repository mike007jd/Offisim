{
  "id": "plan-review-approve-survives-restore",
  "category": "interaction",
  "entryMode": "boss_chat",
  "interactionMode": "human_in_loop",
  "seed": {
    "company": { "companyId": "company-plan-approve", "name": "Plan Approve Co" },
    "thread": { "threadId": "thread-plan-approve", "status": "running" },
    "employees": [{ "id": "emp-plan-approve", "name": "Ari", "role": "engineer" }]
  },
  "tools": [
    {
      "name": "harness-contract",
      "description": "Record deterministic verification evidence.",
      "parameters": {
        "type": "object",
        "properties": { "step": { "type": "string" } }
      }
    }
  ],
  "toolFixtures": {
    "harness-contract": [
      { "success": true, "result": { "ok": true, "step": "approved-work" } }
    ]
  },
  "llmTurns": [
    {
      "id": "pm-plan",
      "match": { "contains": "Plan approved work" },
      "content": "{\"summary\":\"Approved restored plan\",\"steps\":[{\"stepIndex\":0,\"description\":\"Do approved work\",\"tasks\":[{\"taskType\":\"general\",\"employeeId\":\"emp-plan-approve\",\"description\":\"Do approved work\",\"dependsOnStepOutput\":false}]}]}"
    },
    {
      "id": "employee-tool",
      "match": { "contains": "Do approved work", "toolNames": ["harness-contract"] },
      "content": "",
      "toolCalls": [
        {
          "id": "tc-approved-verify",
          "name": "harness-contract",
          "arguments": { "step": "approved-work" }
        }
      ]
    },
    {
      "id": "employee-final",
      "match": { "contains": "approved-work" },
      "content": "APPROVED_RESTORED_PLAN_OUTPUT"
    },
    {
      "id": "consolidator",
      "match": { "contains": "APPROVED_RESTORED_PLAN_OUTPUT" },
      "content": "{\"memories\":[]}"
    }
  ],
  "initialState": {
    "managerDirective": {
      "intent": "Plan approved work",
      "recommendedEmployees": ["emp-plan-approve"]
    }
  },
  "runs": [
    {
      "startAt": "pm_planner",
      "expectError": "PLAN_REVIEW_REQUIRED",
      "resolveAfterRun": [
        {
          "kind": "plan_review",
          "selectedOptionId": "start_execution",
          "restoreBeforeResolve": true
        }
      ]
    },
    { "startAt": "pm_planner" }
  ],
  "assertions": [
    {
      "kind": "interactionHistoryContains",
      "interactionKind": "plan_review",
      "selectedOptionId": "start_execution",
      "status": "resolved",
      "payloadType": "plan_review_payload"
    },
    { "kind": "threadStatusIs", "status": "completed" }
  ]
}
