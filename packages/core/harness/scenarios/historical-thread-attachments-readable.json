{
  "id": "historical-thread-attachments-readable",
  "category": "chat-attachments",
  "entryMode": "boss_chat",
  "interactionMode": "yolo",
  "seed": {
    "company": { "companyId": "company-historical-attachments", "name": "Historical Attachment Co" },
    "thread": { "threadId": "thread-historical-attachments", "status": "running" },
    "employees": [{ "id": "emp-historical-yolo", "name": "YOLO Master", "role": "yolo_master" }]
  },
  "tools": [
    {
      "name": "read_attachment",
      "description": "Read an attached file by vault reference.",
      "parameters": {
        "type": "object",
        "properties": {
          "vaultRef": { "type": "string" },
          "mode": { "type": "string", "enum": ["auto", "text", "binary", "structured"] }
        },
        "required": ["vaultRef"]
      }
    }
  ],
  "toolFixtures": {
    "read_attachment": [
      {
        "success": true,
        "result": {
          "filename": "sample.pdf",
          "mimeType": "application/pdf",
          "byteLength": 4096,
          "sha256": "fixture-sha",
          "content": "Historical PDF page text",
          "truncated": false,
          "structured": { "pages": [{ "pageNumber": 1, "text": "Historical PDF page text" }] }
        }
      }
    ]
  },
  "initialState": {
    "messages": [{ "role": "user", "content": "Summarize the PDF from earlier." }]
  },
  "llmTurns": [
    {
      "id": "employee-sees-earlier-thread-attachment",
      "match": {
        "contains": "Earlier same-thread attachments",
        "toolNames": ["read_attachment"]
      },
      "content": "",
      "toolCalls": [
        {
          "id": "call-historical-read-attachment",
          "name": "read_attachment",
          "arguments": {
            "vaultRef": "attachment://company-historical-attachments/thread-historical-attachments/00000000-0000-4000-8000-000000000444",
            "mode": "structured"
          }
        }
      ]
    },
    {
      "id": "employee-final-after-historical-read",
      "match": { "contains": "Historical PDF page text" },
      "content": "Historical attachment content: Historical PDF page text"
    }
  ],
  "runs": [
    {
      "runScope": {
        "conversationKey": "thread-historical-attachments",
        "runId": "run-historical-attachments",
        "threadId": "thread-historical-attachments",
        "availableAttachments": [
          {
            "attachmentId": "00000000-0000-4000-8000-000000000444",
            "vaultRef": "attachment://company-historical-attachments/thread-historical-attachments/00000000-0000-4000-8000-000000000444",
            "filename": "sample.pdf",
            "mimeType": "application/pdf",
            "byteLength": 4096,
            "kind": "pdf",
            "parsedRev": 1,
            "summary": "PDF · 12 pages"
          }
        ]
      }
    }
  ],
  "assertions": [
    { "kind": "firstGraphNodeIs", "nodeName": "yolo-master" },
    { "kind": "mcpAuditContains", "toolName": "read_attachment" },
    { "kind": "finalOutputContains", "contains": "Historical PDF page text" }
  ]
}
