{
  "id": "routing-accepts-verb-object-imperative",
  "category": "interaction-modes",
  "entryMode": "boss_chat",
  "interactionMode": "boss_proxy",
  "seed": {
    "company": { "companyId": "company-verb-object", "name": "Verb Object Routing Co" },
    "thread": { "threadId": "thread-verb-object", "status": "running" },
    "employees": [
      { "id": "emp-internal-verb", "name": "Internal Worker", "role": "engineer" }
    ]
  },
  "initialState": {
    "messages": [
      {
        "role": "user",
        "content": "Read README.md and quote the install section."
      }
    ]
  },
  "llmTurns": [
    {
      "id": "boss-direct-reply-decision",
      "match": { "contains": "Read README.md and quote" },
      "content": "{\"action\":\"direct_reply\",\"reply\":\"Acknowledged — I will reply briefly.\",\"reason\":\"acknowledging request\"}"
    },
    {
      "id": "boss-direct-reply-text",
      "match": { "contains": "Acknowledged" },
      "content": "Acknowledged — I will reply briefly."
    }
  ],
  "runs": [{}],
  "assertions": [
    {
      "kind": "taskToolIntentEquals",
      "value": { "needsRead": true, "requiresLocalTools": true }
    },
    { "kind": "eventNotEmitted", "eventType": "task.assignment.rerouted" }
  ]
}
