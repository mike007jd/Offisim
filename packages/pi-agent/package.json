{
  "name": "@offisim/pi-agent",
  "version": "1.0.0-rc.1",
  "private": true,
  "type": "module",
  "description": "Offisim vendored fork of @earendil-works/pi-agent-core — the turn-based agent loop only, without the upstream session/compaction harness.",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "node ../../scripts/tsc-build-if-dist-missing.mjs --project tsconfig.json",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@offisim/pi-ai": "workspace:*",
    "typebox": "1.1.38"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "license": "MIT"
}
