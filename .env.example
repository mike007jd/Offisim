# Offisim Local Development
# Copy this file to .env.local and fill in the values you need.
# Root .env.local is used by repo tooling and local platform runs.
#
# AI provider auth and model configuration are owned by Pi Agent:
#   ~/.pi/agent/auth.json
#   ~/.pi/agent/models.json
# Offisim does not read provider API keys from .env.local.

# --- Platform Auth (Better Auth) ---
# BETTER_AUTH_SECRET=your-secret-at-least-32-chars-long
# BETTER_AUTH_URL=http://localhost:4100
# DATABASE_URL=postgres://localhost:5432/aics_platform
# CORS_ORIGINS=http://localhost:3000,http://localhost:5176,http://localhost:1420
# PORT=4100

# --- OAuth Providers (optional, platform API only) ---
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Desktop Renderer Runtime ---
# Marketplace / registry base URL the renderer talks to. Either var works;
# VITE_OFFISIM_REGISTRY_BASE_URL takes precedence, with
# VITE_OFFISIM_PLATFORM_BASE_URL as the fallback. Leave unset to use the
# built-in default.
# VITE_OFFISIM_REGISTRY_BASE_URL=http://localhost:4100
# VITE_OFFISIM_PLATFORM_BASE_URL=http://localhost:4100

# --- macOS Distribution (local DMG signing/notarization) ---
# Used by `pnpm release:dmg`. Keep real values in .env.local only.
# Tauri expects APPLE_PASSWORD to contain the Apple app-specific password.
# APPLE_SIGNING_IDENTITY=Developer ID Application: Your Name (TEAMID)
# APPLE_TEAM_ID=TEAMID
# APPLE_ID=apple-id@example.com
# APPLE_PASSWORD=xxxx-xxxx-xxxx-xxxx
# APPLE_APP_SPECIFIC_PASSWORD=xxxx-xxxx-xxxx-xxxx
