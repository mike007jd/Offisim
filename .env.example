# Offisim Local Development
# Copy this file to .env.local and fill in the values you need.
# Root .env.local is used by repo tooling such as Playwright smoke tests.
# apps/platform reads from the shell environment when started.
# You only need ONE model provider key for smoke tests.
# Model ids below are examples verified 2026-06-06 against each provider's docs
# (see catalog/provider-source-registry); re-check before relying on them.

# --- Anthropic (native adapter) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- OpenAI (native adapter) ---
# OPENAI_API_KEY=sk-...

# --- OpenRouter (openai-compat) ---
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=google/gemma-4-31b-it:free

# --- Kimi (openai-compat) ---
# KIMI_API_KEY=sk-kimi-...
# KIMI_BASE_URL=https://api.kimi.com/coding/v1
# KIMI_MODEL=kimi-for-coding

# --- MiniMax (anthropic-compat / Claude lane) ---
# MINIMAX_API_KEY=sk-cp-...
# MINIMAX_BASE_URL=https://api.minimax.io/anthropic
# MINIMAX_MODEL=MiniMax-M3

# --- MiniMax (openai-compat / Codex lane) ---
# MINIMAX_OPENAI_BASE_URL=https://api.minimax.io/v1
# MINIMAX_OPENAI_MODEL=MiniMax-M3

# --- Z.AI (openai-compat / gateway, not Codex lane) ---
# ZAI_API_KEY=your-zai-api-key
# ZAI_BASE_URL=https://api.z.ai/api/paas/v4
# ZAI_MODEL=glm-5.1

# --- Z.AI (anthropic-compat / Claude lane) ---
# ZAI_ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic
# ZAI_ANTHROPIC_MODEL=glm-5.1

# --- Google Gemini via OpenAI-compat endpoint ---
# GEMINI_API_KEY=AIza...
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# GEMINI_MODEL=gemini-2.5-flash

# --- Platform Auth (Better Auth) ---
# BETTER_AUTH_SECRET=your-secret-at-least-32-chars-long
# BETTER_AUTH_URL=http://localhost:4100
# DATABASE_URL=postgres://localhost:5432/aics_platform
# CORS_ORIGINS=http://localhost:3000,http://localhost:5176,http://localhost:1420
# PORT=4100

# --- OAuth Providers (optional) ---
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Web / Desktop Runtime ---
# VITE_PLATFORM_API_URL=http://localhost:4100
