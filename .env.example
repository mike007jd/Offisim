# AICS Local Development — API Keys
# Copy this file to .env.local and fill in the values you have.
# You only need ONE provider to run smoke tests.

# --- Anthropic (native adapter) ---
# ANTHROPIC_API_KEY=sk-ant-...

# --- OpenAI (native adapter) ---
# OPENAI_API_KEY=sk-...

# --- OpenRouter (openai-compat) ---
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_MODEL=google/gemma-3-4b-it:free

# --- Kimi (openai-compat) ---
# KIMI_API_KEY=sk-kimi-...
# KIMI_BASE_URL=https://api.kimi.com/coding/v1
# KIMI_MODEL=kimi-for-coding

# --- Google Gemini via OpenAI-compat endpoint ---
# GEMINI_API_KEY=AIza...
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# GEMINI_MODEL=gemini-2.5-flash

# --- Platform Auth (Better Auth) ---
# BETTER_AUTH_SECRET=your-secret-at-least-32-chars-long
# BETTER_AUTH_URL=http://localhost:4100
# DATABASE_URL=postgres://localhost:5432/aics_platform

# --- OAuth Providers (optional) ---
# GITHUB_CLIENT_ID=your-github-client-id
# GITHUB_CLIENT_SECRET=your-github-client-secret
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# --- Market App ---
# NEXT_PUBLIC_PLATFORM_API_URL=http://localhost:4100
